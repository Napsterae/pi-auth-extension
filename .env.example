# PI_AUTH_GOOGLE_GEMINI_CLIENT_SECRET=
# PI_AUTH_ANTHROPIC_CLIENT_ID=
# PI_AUTH_OPENAI_CODEX_CLIENT_ID=
# PI_AUTH_XAI_CLIENT_ID=
# PI_AUTH_GITLAB_CLIENT_ID=
# PI_AUTH_GITHUB_COPILOT_CLIENT_ID=
# PI_AUTH_KIMI_CLIENT_ID=
